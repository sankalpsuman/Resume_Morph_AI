rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "sankalpsmn@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'email', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.email is string &&
             data.email.size() > 0 &&
             (data.createdAt is timestamp || data.createdAt == serverTimestamp()) &&
             (!('name' in data) || data.name is string) &&
             (!('photo' in data) || data.photo is string) &&
             (!('morphCount' in data) || data.morphCount is number) &&
             (!('usedMorphs' in data) || data.usedMorphs is number) &&
             (!('freeMorphsUsed' in data) || data.freeMorphsUsed is number) &&
             (!('premiumMorphsUsed' in data) || data.premiumMorphsUsed is number) &&
             (!('remainingMorphs' in data) || data.remainingMorphs is number) &&
             (!('plan' in data) || data.plan is string) &&
             (!('planLimit' in data) || data.planLimit is number) &&
             (!('premiumExpiryDate' in data) || data.premiumExpiryDate is timestamp || data.premiumExpiryDate == null) &&
             (!('adminMessage' in data) || data.adminMessage is string || data.adminMessage == null) &&
             (!('revokeReason' in data) || data.revokeReason is string || data.revokeReason == null) &&
             (!('lastResetAt' in data) || data.lastResetAt is timestamp || data.lastResetAt == null || data.lastResetAt == serverTimestamp()) &&
             (!('lastActivityAt' in data) || data.lastActivityAt is timestamp || data.lastActivityAt == null || data.lastActivityAt == serverTimestamp()) &&
             (!('role' in data) || data.role is string) &&
             (!('resumeHistory' in data) || data.resumeHistory is list);
    }

    function isValidPremiumRequest(data) {
      return data.keys().hasAll(['userId', 'name', 'email', 'selectedPlan', 'price', 'status', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.name is string &&
             data.email is string &&
             data.selectedPlan is string &&
             data.price is number &&
             data.status == 'Pending' &&
             (data.timestamp is timestamp || data.timestamp == serverTimestamp());
    }

    function isValidFeedback(data) {
      return data.keys().hasAll(['name', 'message', 'createdAt', 'uid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 2000 &&
             (data.createdAt is timestamp || data.createdAt == serverTimestamp()) &&
             data.uid == request.auth.uid &&
             (!('email' in data) || data.email is string) &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('rating' in data) || data.rating is number);
    }

    function isValidPremiumInterest(data) {
      return data.keys().hasAll(['email', 'uid', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.email.size() > 0 &&
             (data.timestamp is timestamp || data.timestamp == serverTimestamp());
    }

    function isValidApplication(data) {
      return data.keys().hasAll(['uid', 'company', 'role', 'status', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.company is string && data.company.size() > 0 && data.company.size() < 200 &&
             data.role is string && data.role.size() > 0 && data.role.size() < 200 &&
             data.status in ['Applied', 'Interview', 'Offer', 'Rejected', 'Wishlist'] &&
             (data.createdAt is timestamp || data.createdAt == serverTimestamp()) &&
             (!('location' in data) || (data.location is string && data.location.size() < 200)) &&
             (!('date' in data) || (data.date is string && data.date.size() < 100)) &&
             (!('salary' in data) || (data.salary is string && data.salary.size() < 100)) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() < 5000)) &&
             (!('link' in data) || (data.link is string && data.link.size() < 1000));
    }

    // ===============================================================
    // Collections
    // ===============================================================

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (
        (isOwner(userId) && 
         (
           // Standard profile updates
           !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'plan', 'planLimit', 'premiumExpiryDate', 'createdAt', 'userId']) ||
           // Self-revert to free plan on expiry or revocation
           (request.resource.data.plan == 'free' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['plan', 'planLimit', 'remainingMorphs', 'premiumExpiryDate', 'adminMessage', 'revokeReason']))
         ) &&
         isValidUser(request.resource.data)) ||
        isAdmin()
      );
    }

    match /premium_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidPremiumRequest(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /feedbacks/{feedbackId} {
      // Any customer can see the feedback
      allow read: if true;
      
      // Any authenticated user can create feedback
      allow create: if isAuthenticated() && isValidFeedback(request.resource.data);
      
      // Only admin can update (reply) or delete
      allow update: if isAdmin() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reply']);
      
      allow delete: if isAdmin() || isOwner(resource.data.uid);
    }

    match /premium_interest/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create, update: if isAuthenticated() && isOwner(userId) && isValidPremiumInterest(request.resource.data);
    }

    match /applications/{applicationId} {
      allow list: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow get: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidApplication(request.resource.data);
      allow update: if isAuthenticated() && (
        (resource.data.uid == request.auth.uid && isValidApplication(request.resource.data) && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['company', 'role', 'location', 'status', 'date', 'salary', 'notes', 'link'])) ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }
  }
}
