rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "sankalpsmn@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidFeedback(data) {
      return data.keys().hasAll(['name', 'message', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 1000 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Collections
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create, update: if isAuthenticated() && isOwner(userId) && 
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) || isAdmin());
    }

    match /feedbacks/{feedbackId} {
      // Any customer can see the feedback
      allow read: if true;
      
      // Any authenticated user can create feedback
      allow create: if isAuthenticated() && isValidFeedback(request.resource.data);
      
      // Only admin can update (reply) or delete
      allow update: if isAdmin() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reply']);
      
      allow delete: if isAdmin();
    }
  }
}
