{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and usage tracking",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "morphCount": { "type": "number", "description": "Total morphs ever performed" },
        "usedMorphs": { "type": "number", "description": "Morphs used in current plan" },
        "freeMorphsUsed": { "type": "number", "description": "Morphs used while on free plan" },
        "premiumMorphsUsed": { "type": "number", "description": "Morphs used while on premium plan" },
        "remainingMorphs": { "type": "number", "description": "Morphs remaining in current plan" },
        "plan": { "type": "string", "description": "User's current plan (free, 5_morphs, 10_morphs, unlimited)" },
        "planLimit": { "type": "number", "description": "Max morphs allowed for the user (-1 for unlimited)" },
        "premiumExpiryDate": { "type": "string", "format": "date-time", "description": "Expiry for unlimited plan" },
        "adminMessage": { "type": "string", "description": "Special message from admin (surprise, reset, etc.)" },
        "revokeReason": { "type": "string", "description": "Reason why premium was revoked" },
        "lastActivityAt": { "type": "string", "format": "date-time", "description": "Last time user performed an action" },
        "lastResetAt": { "type": "string", "format": "date-time", "description": "When the usage was last reset" },
        "showResetSurprise": { "type": "boolean", "description": "Whether to show the reset surprise popup" },
        "showRevokeNotice": { "type": "boolean", "description": "Whether to show the premium revoked notice" },
        "role": { "type": "string", "description": "user or admin" },
        "resumeHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "html": { "type": "string" },
              "originalText": { "type": "string" },
              "storagePath": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "required": ["userId", "email", "createdAt"]
    },
    "PremiumRequest": {
      "title": "Premium Request",
      "description": "Manual premium plan requests",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "selectedPlan": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "selectedPlan", "price", "status", "timestamp"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback and admin replies",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "message": { "type": "string" },
        "reply": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "rating": { "type": "number" }
      },
      "required": ["name", "message", "createdAt", "uid"]
    },
    "PremiumInterest": {
      "title": "Premium Interest",
      "description": "Users interested in premium features",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "uid": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "uid", "timestamp"]
    },
    "Application": {
      "title": "Job Application",
      "description": "Job application tracking details",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "company": { "type": "string" },
        "role": { "type": "string" },
        "location": { "type": "string" },
        "status": { 
          "type": "string", 
          "enum": ["Applied", "Interview", "Offer", "Rejected", "Wishlist"] 
        },
        "date": { "type": "string" },
        "salary": { "type": "string" },
        "notes": { "type": "string" },
        "link": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "company", "role", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and usage tracking"
    },
    "/feedbacks/{feedbackId}": {
      "schema": "Feedback",
      "description": "Collection of user feedbacks"
    },
    "/premium_requests/{requestId}": {
      "schema": "PremiumRequest",
      "description": "Manual premium plan requests"
    },
    "/premium_interest/{userId}": {
      "schema": "PremiumInterest",
      "description": "Users interested in premium features"
    },
    "/applications/{applicationId}": {
      "schema": "Application",
      "description": "Job application tracking"
    }
  }
}
